# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - per-installation state, not tracked by upstream.
# Re-include groups we want to preserve (botdanov).
groups/*
!groups/botdanov/

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory must never be committed.
groups/*/CLAUDE.md
**/.claude-shared.md
**/.claude-fragments/

# Secrets inside groups
groups/*/.secrets.env.gpg

# Ephemeral analysis / memory (regenerated)
groups/*/memory/
groups/*/analysis/

# Secrets
*.keys.json
.env
.env*

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
.secrets.env
