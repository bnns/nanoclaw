# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - per-installation state, not tracked. container.json is a
# spawn-materialized output of the container_configs DB row, not source;
# editing or tracking it is fighting the system. See docs/db-central.md §1.15.
# Agent knowledge bases live in their own repos (mounted via additionalMounts).
groups/*

# Composer-managed CLAUDE.md artifacts (regenerated every spawn)
**/.claude-shared.md
**/.claude-fragments/

# Secrets
*.keys.json
.env
.env*

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
.secrets.env
